{
  "name": "obliq-backend",
  "version": "1.0.0",
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start:prod": "node dist/main",
    "seed": "npm run build && node dist/database/seed.js",
    "seed:dev": "SEED_AUTO_SYNC=true npm run seed",
    "seed:reset-admin": "SEED_AUTO_SYNC=true SEED_UPDATE_ADMIN_PASSWORD=true npm run seed",
    "migration:run": "typeorm migration:run -d src/database/data-source.ts",
    "migration:generate": "typeorm migration:generate -d src/database/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/throttler": "^5.1.1",
    "@nestjs/typeorm": "^10.0.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.19",
    "typeorm-extension": "^3.9.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.6",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "typescript": "^5.1.3"
  }
}
